{
  "schemaVersion": 1,
  "id": "itemmodelspawner",
  "version": "${version}",
  "name": "Item Model Spawner",
  "description": "A mod that lets you spawn in Item Displays with an Item Model",
  "authors": [],
  "contact": {},
  "license": "GPL-3.0-or-later",
  "icon": "assets/itemmodelspawner/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "me.iris.itemmodelspawner.client.ItemModelSpawnerDataGenerator"
    ],
    "client": [
      "me.iris.itemmodelspawner.client.ItemModelSpawnerClient"
    ],
    "main": [
      "me.iris.itemmodelspawner.ItemModelSpawner"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
